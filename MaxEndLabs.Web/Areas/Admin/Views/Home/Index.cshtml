@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5 fw-bold"><i class="bi bi-speedometer2 me-2"></i>Admin Control Panel</h1>
            <p class="text-muted">Manage your store's inventory and customer fulfillment.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center p-5">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h3 class="card-title">Product Manager</h3>
                    <p class="card-text text-muted">
                        Add new products, update pricing, manage categories, and track stock levels.
                    </p>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg w-100 mt-3">
                        Go to Products
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-body text-center p-5">
                    <div class="display-4 text-success mb-3">
                        <i class="bi bi-cart-check"></i>
                    </div>
                    <h3 class="card-title">Order Manager</h3>
                    <p class="card-text text-muted">
                        View customer orders, update shipping statuses, and manage payments.
                    </p>
                    <a asp-area="Admin" asp-controller="OrderManagement" asp-action="Index" class="btn btn-success btn-lg w-100 mt-3">
                        Manage Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>