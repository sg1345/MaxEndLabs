@model OrderPaginationViewModel

<div class="card-body p-0">
	@if (Model.Orders.Any())
	{
				<div class="table-responsive">
					<table class="table table-hover align-middle mb-0">
						<thead class="bg-light text-uppercase font-monospace" style="font-size: 1rem;">
						<tr>
							<th class="ps-4 py-3">Date</th>
							<th>Order #</th>
							<th>Status</th>
							<th class="text-end pe-4">Action</th>
						</tr>
						</thead>
						<tbody>
					@foreach (var order in Model.Orders)
					{
								<tr>
									<td class="ps-4 text-muted small">
								@order.CreatedAt.ToString("dd MMM yyyy")
									</td>
									<td>
										<span class="fw-bold text-dark">#@order.OrderNumber</span>
									</td>
									<td>
								@switch (order.Status)
								{
									case "Pending": 
														<span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle">
															<i class="fa-solid fa-clock me-1"></i> Pending
														</span>
										break;

									case "Paid":
														<span class="badge rounded-pill bg-info-subtle text-info-emphasis border border-info-subtle">
															<i class="fa-solid fa-credit-card me-1"></i> Paid
														</span>
										break;

									case "Shipped": 
														<span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle">
															<i class="fa-solid fa-truck-fast me-1"></i> Shipped
														</span>
										break;

									case "Completed": 
														<span class="badge rounded-pill bg-success-subtle text-success-emphasis border border-success-subtle">
															<i class="fa-solid fa-check-double me-1"></i> Completed
														</span>
										break;

									case "Cancelled":
									case "Refunded": 
														<span class="badge rounded-pill bg-danger-subtle text-danger-emphasis border border-danger-subtle">
															<i class="fa-solid fa-ban me-1"></i> @order.Status
														</span>
										break;
								}
									</td>
									<td class="text-end pe-4">
										<div class="btn-group">
											<button type="button" 
											        class="btn btn-sm btn-light border shadow-sm view-details-btn"
													data-url="@Url.Action("Details", "OrderManagement", new {area = "Admin"})" 
											        data-id="@order.Id">
												Details
											</button>
										</div>
									</td>
								</tr>
					}
						</tbody>
					</table>
				</div>

				<div id="orderBoxContainer">
					<div class="card-footer bg-white border-top-0 pb-4 px-4 d-flex justify-content-center">
						<nav aria-label="Order pagination">
							<ul class="pagination pagination-sm mb-0 shadow-sm">
								<li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
									<a class="page-link border-0" asp-action="Index" asp-route-page="1" title="First Page">
										<i class="fa-solid fa-angles-left"></i>
									</a>
								</li>

								<li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
											<a class="page-link border-0" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">
										<i class="fa-solid fa-chevron-left"></i>
									</a>
								</li>

						@for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
						{
							if (i > 0 && i <= Model.TotalPages)
							{
												<li class="page-item @(i == Model.CurrentPage ? "active" : "")">
																<a class="page-link border-0 rounded-3 mx-1" asp-action="Index" asp-route-page="@i">@i</a>
												</li>
							}
						}

								<li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
										<a class="page-link border-0" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">
										<i class="fa-solid fa-chevron-right"></i>
									</a>
								</li>

								<li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
										<a class="page-link border-0" asp-action="Index" asp-route-page="@Model.TotalPages" title="Last Page">
										<i class="fa-solid fa-angles-right"></i>
									</a>
								</li>
							</ul>
						</nav>
					</div>
				</div>
	}
	else
	{
				<div class="text-center py-5">
					<img src="~/images/empty-box.png" alt="No Orders" style="width: 60px; opacity: 0.3;" class="mb-3">
					<p class="text-muted">No orders found.</p>
				</div>
	}
	</div>