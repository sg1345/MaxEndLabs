@{
	ViewData["Title"] = "MaxEndLabs News";
}

<div class="container my-5">
	<div class="row">
		<div class="col-lg-8">


			@if (User.Identity is { IsAuthenticated: true })
			{
				<article class="mb-5 border-bottom">
					<div class="row justify-content-center mb-4">
						<div id="orderBoxFullWrapper">
							@await Component.InvokeAsync("OrderBox", new { page = 1 })
						</div>
					</div>
				</article>
			}

			<partial name="_Euro2026ArticlePartial"/>
			<partial name="_KarlosStoryArticlePartial"/>

			<article class="mb-5">
				<div class="row">
					<div class="col-md-5">
						<img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=600" class="img-fluid rounded" alt="Clean and Jerk">
					</div>
					<div class="col-md-7">
						<div class="category-badge mb-2 text-danger fw-bold">GUIDES & TUTORIALS</div>
						<h3 class="fw-bold">How to Clean and Jerk: A Quick Guide</h3>
						<p>The Clean and Jerk is the ultimate test of total body power. Follow these three phases to perfect your form:</p>
						<ul class="list-unstyled">
							<li><strong>1. The Pull:</strong> Keep the bar close. Explode through the hips.</li>
							<li><strong>2. The Catch:</strong> Drop under the bar fast into a front squat.</li>
							<li><strong>3. The Jerk:</strong> Use your legs to drive the bar overhead while splitting your feet.</li>
						</ul>
					</div>
				</div>
			</article>

		</div>

		<div class="col-lg-4">
			<div class="sticky-top" style="top: 20px;">
				<div class="p-4 bg-light rounded shadow-sm text-center">
					<h4 class="fw-bold mb-3">SHOP OUR GEAR</h4>
					<p class="small text-muted mb-4">Support your training with professional grade equipment used by the best.</p>

					<a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg w-100 rounded-pill shadow">
						Go to Store
					</a>

					<div class="mt-4 pt-4 border-top">
						<h6>The Athlete's Checklist:</h6>
						<ul class="list-unstyled small text-start">
							<li class="mb-2">💊 <strong>Elite Whey & Creatine</strong> - Pure Recovery</li>
							<li class="mb-2">👟 <strong>MaxStability Lifters</strong> - For Heavy Days</li>
							<li class="mb-2">👕 <strong>Oversized Pump Covers</strong> - Breathable Cotton</li>
							<li class="mb-2">🩳 <strong>Mesh Training Shorts</strong> - Zero Restriction</li>
							<li class="mb-2">🎗️ <strong>Figure-8 Lifting Straps</strong> - Locked-in Grip</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<partial name="_OrderModalShell"/>


@section Scripts {
	<script src="~/js/orderDetails.js"></script>
	<script src="~/js/orderHomePagination.js"></script>
}
