@model string
@{
	ViewData["Title"] = "Confirming Payment";
}

<section class="vh-100 d-flex align-items-center justify-content-center bg-light">
	<div class="card shadow-lg border-0 rounded-4" style="max-width: 500px; width: 90%;">
		<div class="card-body p-5 text-center">
			<div class="mb-4">
				<div class="spinner-grow text-success" role="status" style="width: 3rem; height: 3rem;">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>

			<h1 class="fw-bold mb-3">Payment received.</h1>
			<p class="text-muted mb-4">Confirming with our systems... <br /> This page will refresh in a few seconds.</p>
            
			<div class="d-grid gap-2">
				<button onclick="location.reload()" class="btn btn-primary btn-lg rounded-pill shadow-sm">
					<i class="bi bi-arrow-clockwise me-2"></i>Refresh Now
				</button>
			</div>
            
			<div class="mt-4 small text-uppercase text-tracking fw-semibold text-secondary">
				Current Status: <span class="text-dark">@Model</span>
			</div>
		</div>
	</div>
</section>

<script>
    setTimeout(() => {
        location.reload();
    }, 4000);
</script>