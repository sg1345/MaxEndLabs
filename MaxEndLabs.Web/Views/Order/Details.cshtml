@using System.Security.Claims
@model MaxEndLabs.ViewModels.Order.OrderDetailsViewModel

<div class="container mt-4">
    <div class="card shadow">
	    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
		    <div>
			    <h4 class="mb-0">Order #@Model.OrderNumber</h4>
			    <small class="opacity-75">Placed on @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
		    </div>
		    <span class="badge rounded-pill @Model.StatusBadgeClass fs-6">
			    @Model.Status
		    </span>
	    </div>
        <div class="card-body">
            <div class="row mb-4">
	            <div class="col-sm-6">
		            <h6 class="text-muted">Customer Information:</h6>
		            <div><strong>@Model.OwnerFullName</strong></div>
		            <div>@Model.OwnerUsername</div>
	            </div>
				
	            <div class="col-sm-6 text-sm-end">
		            <h6 class="text-muted text-uppercase small fw-bold">Shipping Address</h6>
		            <div>@Model.StreetAddress</div>
		            <div>@Model.City</div>
		            <div>@Model.Postcode</div>
	            </div>
            </div>

            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                            <tr>
                                <td>
	                                <div class="d-flex align-items-center">
		                                @if (string.IsNullOrEmpty(@item.ImageUrl))
		                                {
			                                <img src = "~/images/default_product_image.jpg" alt="" style="width: 50px; height: 50px; object-fit: cover;" class="rounded me-3"/>
		                                }
		                                else
		                                {
			                                <img src="@item.ImageUrl" alt="" style="width: 50px; height: 50px; object-fit: cover;" class="rounded me-3"/>
		                                }
		                               
		                                <div>
			                                <div class="fw-bold">@item.ProductName</div>
			                                <small class="text-muted">Variant: @item.VariantName</small>
		                                </div>
	                                </div>
                                </td>
                                <td>@item.Price.ToString("C")</td>
                                <td>@item.Quantity</td>
                                <td class="text-end fw-bold">@item.LineTotal.ToString("C")</td>
                            </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold fs-5">Grand Total:</td>
                        <td class="text-end fw-bold fs-5 text-success">@Model.TotalAmount.ToString("C")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
	    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
		    <div>
			    <a href="javascript:void(0);" onclick="history.back();" class="btn btn-outline-secondary">
				    <i class="bi bi-arrow-left"></i> Back
			    </a>
		    </div>
		    <div>
			    @if (Model.Status == "Pending" && Model.OwnerUserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
			    {
				    <a asp-controller="Order" asp-action="StripeCheckout" asp-route-orderId="@Model.OrderId" class="btn btn-primary">
					    Pay Now
				    </a>
			    }
        
			    @if (User.IsInRole("Admin"))
			    {
				    <button type="submit" form="statusForm" class="btn btn-success ms-2">
					    Apply Changes
				    </button>
			    }
		    </div>
	    </div>
    </div>
</div>