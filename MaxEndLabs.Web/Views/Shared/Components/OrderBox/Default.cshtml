@model MaxEndLabs.ViewModels.Order.OrderPaginationViewModel

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
	<div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
		<div>
			<h4 class="fw-bold mb-0 text-dark">Your Activity</h4>
			<p class="text-muted small mb-0">Track and manage your recent orders</p>
		</div>
		<i class="fa-solid fa-clock-rotate-left text-primary fs-4"></i>
	</div>

	<div class="card-body p-0">
		@if (Model.Orders.Any())
		{
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="bg-light text-uppercase font-monospace" style="font-size: 1rem;">
					<tr>
						<th class="ps-4 py-3">Date</th>
						<th>Order #</th>
						<th>Status</th>
						<th class="text-end pe-4">Action</th>
					</tr>
					</thead>
					<tbody>
					@foreach (var order in Model.Orders)
					{
						<tr>
							<td class="ps-4 text-muted small">
								@order.CreatedAt.ToString("dd MMM yyyy")
							</td>
							<td>
								<span class="fw-bold text-dark">#@order.OrderNumber</span>
							</td>
							<td>
								@switch (order.Status)
								{
									case "Pending": 
										<span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle">
											<i class="fa-solid fa-clock me-1"></i> Pending
										</span>
										break;

									case "Paid":
										<span class="badge rounded-pill bg-info-subtle text-info-emphasis border border-info-subtle">
											<i class="fa-solid fa-credit-card me-1"></i> Paid
										</span>
										break;

									case "Shipped": 
										<span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle">
											<i class="fa-solid fa-truck-fast me-1"></i> Shipped
										</span>
										break;

									case "Completed": 
										<span class="badge rounded-pill bg-success-subtle text-success-emphasis border border-success-subtle">
											<i class="fa-solid fa-check-double me-1"></i> Completed
										</span>
										break;

									case "Cancelled": 
									case "Refund": 
										<span class="badge rounded-pill bg-danger-subtle text-danger-emphasis border border-danger-subtle">
											<i class="fa-solid fa-ban me-1"></i> @order.Status
										</span>
										break;
								}
							</td>
							<td class="text-end pe-4">
								<div class="btn-group">
									<a asp-controller="Order" asp-action="Details" asp-route-orderId="@order.Id" 
									   class="btn btn-sm btn-light border shadow-sm">
										Details
									</a>
									@if (order.Status == "Pending")
									{
										<a asp-controller="Order" asp-action="StripeCheckoutSession" asp-route-orderId="@order.Id" 
										   class="btn btn-sm btn-primary shadow-sm">
											Pay
										</a>
									}
								</div>
							</td>
						</tr>
					}
					</tbody>
				</table>
			</div>

			<div id="orderBoxContainer">
				<div class="card-footer bg-white border-top-0 pb-4 px-4 d-flex justify-content-center">
					<nav aria-label="Order pagination">
						<ul class="pagination pagination-sm mb-0 shadow-sm">
							<li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
								<a class="page-link border-0" href="javascript:void(0)" onclick="loadOrderPage(1)" title="First Page">
									<i class="fa-solid fa-angles-left"></i>
								</a>
							</li>

							<li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
								<a class="page-link border-0" href="javascript:void(0)" onclick="loadOrderPage(@(Model.CurrentPage - 1))">
									<i class="fa-solid fa-chevron-left"></i>
								</a>
							</li>

							@for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
							{
								if (i > 0 && i <= Model.TotalPages)
								{
									<li class="page-item @(i == Model.CurrentPage ? "active" : "")">
										<a class="page-link border-0 rounded-3 mx-1" href="javascript:void(0)" onclick="loadOrderPage(@i)">@i</a>
									</li>
								}
							}

							<li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
								<a class="page-link border-0" href="javascript:void(0)" onclick="loadOrderPage(@(Model.CurrentPage + 1))">
									<i class="fa-solid fa-chevron-right"></i>
								</a>
							</li>

							<li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
								<a class="page-link border-0" href="javascript:void(0)" onclick="loadOrderPage(@Model.TotalPages)" title="Last Page">
									<i class="fa-solid fa-angles-right"></i>
								</a>
							</li>
						</ul>
					</nav>
				</div>
			</div>
		}
		else
		{
			<div class="text-center py-5">
				<img src="~/images/empty-box.png" alt="No Orders" style="width: 60px; opacity: 0.3;" class="mb-3">
				<p class="text-muted">No orders found.</p>
			</div>
		}
	</div>
	
</div>

<script>
	function loadOrderPage(pageNum) {
		$.get('/Home/GetOrderBox?page=' + pageNum, function (data) {
			$('#orderBoxFullWrapper').html(data);
		});
	}
</script>