<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MaxEndLabs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MaxEndLabs.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/logo.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js" integrity="sha512-lbwH47l/tPXJYG9AcFNoJaTMhGvYWhVM9YI43CT+uteTRRaiLCui8snIgyAN8XWgNjNhCqlAUdzZptso6OCoFQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body>
<header>
	<partial name="_NotificationPartial"/>
	<nav class="navbar navbar-expand-md navbar-light bg-white border-bottom shadow-sm py-3 mb-4">
		<div class="container-fluid">
			<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
				<img src="~/images/brand-navbar.png" class="nav-logo"/>
			</a>
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
			        aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
				<ul class="navbar-nav flex-grow-1">
					@await Component.InvokeAsync("CategoryMenu")
					@if (User.IsInRole("Admin"))
					{
						<li class="nav-item">
							<a class="nav-link text-dark fw-bold text-uppercase fs-5 px-3"
							   asp-area="Admin" asp-controller="ProductManagement" asp-action="Index" title="ProductManager">
								<i class="fa-solid fa-box-open me-2"></i>
								Product Manager
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link text-dark fw-bold text-uppercase fs-5 px-3"
							   asp-area="Admin" asp-controller="OrderManagement" asp-action="Index" title="OrderManager">
								<i class="fa-solid fa-clipboard-list me-2"></i>
								Order Manager
							</a>
						</li>
					}
				</ul>
				<partial name="_LoginPartial"/>
			</div>
		</div>
	</nav>
</header>
<div class="container">
	<main role="main" class="pb-3">
		@RenderBody()
	</main>
</div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MaxEndLabs - <a asp-area="" asp-controller="Home" asp-action="AboutUs">About Us</a>
        </div>
    </footer>
    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
